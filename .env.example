# Copy this to .env and fill values
# Neon Postgres connection string.
# Prefer the pooled URL from the Neon dashboard for deployed/serverless apps.
# Example: postgresql://user:password@ep-example-pooler.us-east-2.aws.neon.tech/dbname?sslmode=require
NEON_DATABASE_URL=
# DATABASE_URL is still supported as a fallback if your host provides that name.
DATABASE_URL=
APIFY_TOKEN=
APIFY_ACTOR_ID=apify/yahoo-finance-scraper
NEYNAR_API_KEY=
CRON_SECRET=
MARKET_CLOSE_HOUR=16
MARKET_CLOSE_MINUTE=30
# Optional: set to an importable module that exposes run_workflow(portfolio_id=None).
ROMA_FRAMEWORK_MODULE=
